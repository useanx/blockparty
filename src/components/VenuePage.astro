---
import Layout from '../layouts/Layout.astro';
import type { Venue } from '../data/venues';

interface Props {
  venue: Venue;
  menuPdf?: string;
}

const { venue, menuPdf = '/menu.pdf' } = Astro.props;
---

<Layout
  title={venue.seo.title}
  description={venue.seo.description}
>

  <!-- HERO -->
  <section style="position: relative; min-height: 70vh; display: flex; align-items: flex-end; overflow: hidden; background: #111;">
    <img
      src={`/images/venue-${venue.slug}-hero.jpg`}
      alt={venue.name}
      style="position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0.55;"
    />
    <div style="position: relative; z-index: 1; padding: 3rem 1.5rem; max-width: 1280px; margin: 0 auto; width: 100%;">
      <h1 class="heading_h1" style="color: #fff; margin: 0 0 1rem;">{venue.heroHeading}</h1>
      <p class="subheading" style="color: rgba(255,255,255,0.85); max-width: 540px; margin: 0 0 2rem;">
        {venue.heroSubheading}
      </p>
      <div style="display: flex; gap: 1rem; flex-wrap: wrap;">
        <a href="/host-your-event" class="button on-inverse">Host Your Event</a>
        <a href={menuPdf} target="_blank" rel="noopener noreferrer" class="button on-inverse is-secondary">View Menu</a>
      </div>
    </div>
  </section>

  <!-- DESCRIPTION -->
  <section style="max-width: 1280px; margin: 0 auto; padding: 6rem 1.5rem;">
    <div id="desc-grid" style="display: grid; grid-template-columns: 1fr; gap: 4rem; align-items: start;">
      <div>
        <h2 class="heading_h2" style="margin: 0 0 2rem;">{venue.descriptionHeading}</h2>
        {venue.descriptionBody.map(para => (
          <p class="paragraph_large text-color_secondary" style="margin: 0 0 1.5rem;">{para}</p>
        ))}
      </div>
      <div style="display: flex; flex-direction: column; gap: 1rem;">
        <div style="background: #f9fafb; border-radius: 1rem; padding: 2rem; border: 1px solid #e5e7eb;">
          <p class="eyebrow" style="margin: 0 0 0.75rem;">Discover our venues</p>
          <h3 class="heading_h2" style="margin: 0 0 0.5rem;">{venue.name}</h3>
          
            href={`https://maps.google.com/?q=${encodeURIComponent(venue.address)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="text-link big"
            style="display: inline-block; margin-bottom: 1.5rem;"
          >
            {venue.address}
          </a>
          <div style="border-top: 1px solid #e5e7eb; padding-top: 1.5rem;">
            <a href="/host-your-event" class="button" style="width: 100%; text-align: center; display: block;">
              Book This Space
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- DETAIL / SECOND IMAGE -->
  <section style="background: #f9fafb; padding: 6rem 1.5rem;">
    <div style="max-width: 1280px; margin: 0 auto;">
      <h2 class="heading_h2" style="margin: 0 0 1.5rem; text-align: center;">Your Event, Our Canvas</h2>
      <div id="detail-grid" style="display: grid; grid-template-columns: 1fr; gap: 3rem; align-items: center; margin-top: 3rem;">
        <img
          src={`/images/venue-${venue.slug}-detail.jpg`}
          alt={`${venue.name} event space`}
          style="width: 100%; aspect-ratio: 16/9; object-fit: cover; border-radius: 1rem; background: #e5e7eb;"
        />
        <div>
          <h3 class="heading_h3" style="margin: 0 0 1.5rem;">{venue.detailHeading}</h3>
          <p class="paragraph_large" style="margin: 0 0 2rem; color: #4b5563;">{venue.detailBody}</p>
          <a href="/host-your-event" class="button">Get Started</a>
        </div>
      </div>
    </div>
  </section>

  <!-- WHY BLOCK PARTY -->
  <section style="max-width: 1280px; margin: 0 auto; padding: 6rem 1.5rem;">
    <div id="why-grid" style="display: grid; grid-template-columns: 1fr; gap: 4rem; align-items: center;">
      <div>
        <p class="eyebrow" style="margin: 0 0 0.75rem;">Why Choose Block Party?</p>
        <h2 class="heading_h2" style="margin: 0 0 1rem;">Designed for Connection. Crafted for You.</h2>
        <p class="paragraph_large" style="margin: 0 0 2rem; color: #4b5563;">
          We blend atmosphere, cuisine, and service to create events that feel effortless and unforgettable. Our team handles every detail, so you can focus on what matters — bringing people together.
        </p>
        <a href="/host-your-event" class="button">Get Started</a>
      </div>
      <img
        src={`/images/venue-${venue.slug}-why.jpg`}
        alt="Why choose Block Party"
        style="width: 100%; aspect-ratio: 4/3; object-fit: cover; border-radius: 1rem; background: #f3f4f6;"
      />
    </div>
  </section>

  <!-- THREE FEATURES -->
  <section style="background: #f9fafb; padding: 6rem 1.5rem;">
    <div style="max-width: 1280px; margin: 0 auto;">
      <p class="eyebrow" style="text-align: center; margin: 0 0 0.75rem;">Distinctive Venues. Inspired Gatherings.</p>
      <h2 class="heading_h2" style="text-align: center; margin: 0 0 3rem;">Host Boldly. Celebrate Creatively.</h2>
      <div id="features-grid" style="display: grid; grid-template-columns: 1fr; gap: 2rem;">

        <div style="background: #fff; border-radius: 1rem; padding: 2rem; border: 1px solid #e5e7eb;">
          <h3 class="heading_h4" style="margin: 0 0 0.75rem;">Versatile event venues</h3>
          <p class="paragraph" style="margin: 0; color: #4b5563;">
            Choose from unique spaces — loft-style, indoor-outdoor patios, or exposed brick backdrops — each tailored for gatherings of any size, from intimate dinners to large-scale activations.
          </p>
        </div>

        <div style="background: #fff; border-radius: 1rem; padding: 2rem; border: 1px solid #e5e7eb;">
          <h3 class="heading_h4" style="margin: 0 0 0.75rem;">Chef-crafted catering</h3>
          <p class="paragraph" style="margin: 0; color: #4b5563;">
            Enjoy globally inspired menus, seasonal ingredients, and creative setups like taco bars or handcrafted specialties, with options for delivery or full-service experiences.
          </p>
        </div>

        <div style="background: #fff; border-radius: 1rem; padding: 2rem; border: 1px solid #e5e7eb;">
          <h3 class="heading_h4" style="margin: 0 0 0.75rem;">Effortless planning</h3>
          <p class="paragraph" style="margin: 0; color: #4b5563;">
            Our team handles every detail, from layout to logistics, ensuring a seamless process and a welcoming atmosphere for you and your guests.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- BOTTOM CTA -->
  <section style="padding: 6rem 1.5rem; text-align: center;">
    <div style="max-width: 600px; margin: 0 auto;">
      <h2 class="heading_h2" style="margin: 0 0 2rem;">Plan your next unforgettable event</h2>
      <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
        <a href="/host-your-event" class="button">Get Started</a>
        <a href="/venues" class="button is-secondary">View all venues</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  @media (min-width: 768px) {
    #desc-grid     { grid-template-columns: 1.5fr 1fr !important; }
    #detail-grid   { grid-template-columns: 1fr 1fr !important; }
    #why-grid      { grid-template-columns: 1fr 1fr !important; }
    #features-grid { grid-template-columns: repeat(3, 1fr) !important; }
  }
</style>