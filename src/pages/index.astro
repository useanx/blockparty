---
import Layout from '../layouts/Layout.astro';
import { venues } from '../data/venues';
---

<Layout
  title="Distinctive Event Venues & Catering in San Francisco"
  description="Distinctive venues. Inspired cuisine. Effortless events, crafted for San Francisco's boldest gatherings. Discover your next unforgettable experience with Block Party Productions."
>

  <!-- HERO -->
  <section style="position: relative; min-height: 90vh; display: flex; align-items: center; justify-content: center; overflow: hidden; background: #111;">
    <img
      src="/images/hero-home.jpg"
      alt="Block Party Productions event"
      style="position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0.5;"
    />
    <div style="position: relative; z-index: 1; text-align: center; padding: 2rem 1.5rem; max-width: 900px; margin: 0 auto;">
     <h1 class="heading_h1 hero-text" style="color: #fff; margin: 0 0 1.5rem;"></h1>
        Gather. Celebrate. Savor Every Moment.
      </h1>
      <p class="subheading hero-text-delay" style="color: rgba(255,255,255,0.85); max-width: 600px; margin: 0 auto 2.5rem;"></p>
        Distinctive venues. Inspired cuisine. Effortless events, crafted for San Francisco's boldest gatherings. Discover your next unforgettable experience with Block Party Productions.
      </p>
      <div class="hero-text-delay-2" style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
        <a href="/venues" class="button on-inverse">Explore Our Venues</a>
        <a href="/host-your-event" class="button on-inverse is-secondary">Plan Your Event</a>
      </div>
    </div>
  </section>

  <!-- INTRO -->
  <section style="max-width: 1280px; margin: 0 auto; padding: 6rem 1.5rem;">
    <div id="intro-grid" style="display: grid; grid-template-columns: 1fr; gap: 4rem; align-items: center;">
      <div>
        <h2 class="heading_h3 reveal" style="margin: 0 0 1.5rem;">Gather, connect, make it unforgettable</h2>
        <p class="paragraph_large" style="margin: 0 0 2rem;">
          Host your next event in a space that feels as unique as your vision. Our flexible venues and chef-led catering make planning effortless, whether it's a team offsite, milestone celebration, or creative pop-up. Let us handle the details so you can focus on what matters: sharing moments and making memories.
        </p>
        <a href="/venues" class="button is-secondary">Browse venues</a>
      </div>
      <div class="reveal reveal-image reveal-right" style="border-radius: 1rem; overflow: hidden; aspect-ratio: 4/3; background: #f3f4f6;">
        <img
          src="/images/intro-gathering.jpg"
          alt="Beautiful event gathering"
          style="width: 100%; height: 100%; object-fit: cover;"
        />
      </div>
    </div>
  </section>

  <!-- THREE VALUE PROPS -->
  <section style="background: #f9fafb; padding: 6rem 1.5rem;">
    <div style="max-width: 1280px; margin: 0 auto;">
      <div id="value-grid" style="display: grid; grid-template-columns: 1fr; gap: 3rem;">

        <div class="reveal reveal-delay-1" style="display: flex; flex-direction: column; gap: 1rem;">
          <img
            src="/images/venue-spaces.jpg"
            alt="Event venues with character"
            style="width: 100%; aspect-ratio: 16/9; object-fit: cover; border-radius: 0.75rem; background: #e5e7eb;"
          />
          <h3 class="heading_h4" style="margin: 0;">Spaces with character, ready for you</h3>
          <p class="paragraph_large" style="margin: 0; color: #4b5563;">
            From cozy dinners to vibrant parties, our venues offer distinctive backdrops and thoughtful amenities. Each space is designed to inspire connection and bring your gathering to life, no matter the size or style.
          </p>
          <a href="/venues" class="button is-secondary" style="align-self: flex-start;">See spaces</a>
        </div>

        <div class="reveal reveal-delay-2" style="display: flex; flex-direction: column; gap: 1rem;">
          <img
            src="/images/catering-menus.jpg"
            alt="Chef-crafted menus"
            style="width: 100%; aspect-ratio: 16/9; object-fit: cover; border-radius: 0.75rem; background: #e5e7eb;"
          />
          <h3 class="heading_h4" style="margin: 0;">Menus that spark conversation</h3>
          <p class="paragraph_large" style="margin: 0; color: #4b5563;">
            Savor dishes inspired by global flavors and crafted with local, seasonal ingredients. Choose from interactive stations or elegant plated meals — our team brings creativity and care to every bite.
          </p>
          <a href="/catering" class="button is-secondary" style="align-self: flex-start;">View menus</a>
        </div>

        <div class="reveal reveal-delay-3" style="display: flex; flex-direction: column; gap: 1rem;">
          <img
            src="/images/event-planning.jpg"
            alt="Effortless event planning"
            style="width: 100%; aspect-ratio: 16/9; object-fit: cover; border-radius: 0.75rem; background: #e5e7eb;"
          />
          <h3 class="heading_h4" style="margin: 0;">Planning made easy for you</h3>
          <p class="paragraph_large" style="margin: 0; color: #4b5563;">
            Let our team handle the details: set-up, service, and everything in between — so you can relax and enjoy every moment.
          </p>
          <a href="/host-your-event" class="button is-secondary" style="align-self: flex-start;">Get started</a>
        </div>

      </div>
    </div>
  </section>

  <!-- TESTIMONIAL -->
  <section style="max-width: 800px; margin: 0 auto; padding: 6rem 1.5rem; text-align: center;">
    <p class="paragraph_xlarge reveal" style="margin: 0 0 2rem;">
      "Everyone was amazing! We truly enjoyed it. The food was great, the drinks were great. I personally loved that the bartender was able to make virgin drinks too that were absolutely delicious. Omar and Amber took care of us, and the staff that waited on us was a pleasure to work with. I don't know when our next event is in SF, but we will definitely be coming back."
    </p>
    <p style="font-weight: 600; margin: 0 0 0.25rem;">Rosie Pann</p>
    <p class="paragraph_small text-color_secondary" style="margin: 0;">McCarthy Building Companies, San Francisco</p>
  </section>

  <!-- VENUES GRID -->
  <section style="max-width: 1280px; margin: 0 auto; padding: 0 1.5rem 6rem;">
    <div class="reveal" style="text-align: center; margin-bottom: 3rem;">
      <p class="eyebrow" style="margin: 0 0 0.75rem;">Venues &amp; catering</p>
      <h2 class="heading_h2" style="margin: 0;">Gatherings made unforgettable</h2>
    </div>
    <div id="venues-grid" style="display: grid; grid-template-columns: 1fr; gap: 2rem;">
      {venues.map(venue => (
        <div style="border: 1px solid #e5e7eb; border-radius: 1rem; overflow: hidden; display: flex; flex-direction: column;">
          <div style="aspect-ratio: 16/9; background: #f3f4f6; overflow: hidden;">
            <img
              src={`/images/venue-${venue.slug}.jpg`}
              alt={venue.name}
              style="width: 100%; height: 100%; object-fit: cover;"
            />
          </div>
          <div style="padding: 1.5rem; display: flex; flex-direction: column; gap: 0.5rem; flex: 1;">
            <p class="paragraph_small text-color_secondary" style="margin: 0;">Venue</p>
            <h3 class="heading_h4" style="margin: 0;">{venue.name}</h3>
            <p class="address" style="margin: 0;">{venue.address}</p>
            <p class="paragraph" style="margin: 0; color: #4b5563; flex: 1;">{venue.tagline}</p>
            <a href={`/${venue.slug}`} class="button is-secondary" style="align-self: flex-start; margin-top: 0.5rem;">View Venue</a>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- PARTNER LOGOS -->
  <section style="background: #f9fafb; padding: 4rem 1.5rem;">
    <div style="max-width: 1280px; margin: 0 auto; text-align: center;">
      <h3 class="heading_h3" style="margin: 0 0 0.75rem;">Trusted by Industry Leaders</h3>
      <p class="subheading" style="max-width: 600px; margin: 0 auto 3rem;">
        We're proud to partner with innovative companies and community leaders who share our passion for unforgettable gatherings.
      </p>
      <p class="paragraph_small text-color_secondary" style="margin: 0;">
        Add your partner logo images to <code>/public/images/</code> and update the src attributes below.
      </p>
      <div id="logos-grid" style="display: flex; flex-wrap: wrap; gap: 2rem; justify-content: center; align-items: center; margin-top: 2rem;">
        <img src="/images/partner-1.png" alt="Partner" style="height: 2rem; width: auto; opacity: 0.6; object-fit: contain;" />
        <img src="/images/partner-2.png" alt="Partner" style="height: 2rem; width: auto; opacity: 0.6; object-fit: contain;" />
        <img src="/images/partner-3.png" alt="Partner" style="height: 2rem; width: auto; opacity: 0.6; object-fit: contain;" />
        <img src="/images/partner-4.png" alt="Partner" style="height: 2rem; width: auto; opacity: 0.6; object-fit: contain;" />
        <img src="/images/partner-5.png" alt="Partner" style="height: 2rem; width: auto; opacity: 0.6; object-fit: contain;" />
        <img src="/images/partner-6.png" alt="Partner" style="height: 2rem; width: auto; opacity: 0.6; object-fit: contain;" />
        <img src="/images/partner-7.png" alt="Partner" style="height: 2rem; width: auto; opacity: 0.6; object-fit: contain;" />
        <img src="/images/partner-8.png" alt="Partner" style="height: 2rem; width: auto; opacity: 0.6; object-fit: contain;" />
        <img src="/images/partner-9.png" alt="Partner" style="height: 2rem; width: auto; opacity: 0.6; object-fit: contain;" />
      </div>
    </div>
  </section>

  <!-- BLOG/EDITORIAL TEASERS -->
  <section style="max-width: 1280px; margin: 0 auto; padding: 6rem 1.5rem;">
    <h2 class="heading_h2" style="margin: 0 0 3rem;">Fresh ideas for every gathering</h2>
    <div id="editorial-grid" style="display: grid; grid-template-columns: 1fr; gap: 2rem;">

      <div style="display: grid; grid-template-columns: 1fr; gap: 1.5rem; border: 1px solid #e5e7eb; border-radius: 1rem; overflow: hidden;">
        <img src="/images/editorial-1.jpg" alt="Host unforgettable events" style="width: 100%; aspect-ratio: 16/9; object-fit: cover; background: #f3f4f6;" />
        <div style="padding: 1.5rem;">
          <span class="tag" style="margin-bottom: 0.75rem; display: inline-block;">Event planning</span>
          <h3 class="heading_h2" style="margin: 0 0 0.75rem;">Host unforgettable events with ease</h3>
          <p class="subheading" style="margin: 0;">
            Get practical advice for seamless planning, from choosing the right space to creating a menu that brings people together.
          </p>
        </div>
      </div>

      <div style="display: grid; grid-template-columns: 1fr; gap: 1.5rem; border: 1px solid #e5e7eb; border-radius: 1rem; overflow: hidden;">
        <img src="/images/editorial-2.jpg" alt="SoMa venues" style="width: 100%; aspect-ratio: 16/9; object-fit: cover; background: #f3f4f6;" />
        <div style="padding: 1.5rem;">
          <span class="tag margin-bottom_xsmall" style="display: inline-block;">Venue spotlight</span>
          <h3 class="heading_h4" style="margin: 0.75rem 0;">Discover SoMa's standout event spaces</h3>
          <p class="paragraph" style="margin: 0; color: #4b5563;">
            Step inside flexible venues with unique character and prime locations — perfect for team offsites, milestone parties, and everything in between.
          </p>
        </div>
      </div>

      <div style="display: grid; grid-template-columns: 1fr; gap: 1.5rem; border: 1px solid #e5e7eb; border-radius: 1rem; overflow: hidden;">
        <img src="/images/editorial-3.jpg" alt="Bay Area catering" style="width: 100%; aspect-ratio: 16/9; object-fit: cover; background: #f3f4f6;" />
        <div style="padding: 1.5rem;">
          <span class="tag margin-bottom_xsmall" style="display: inline-block;">Catering</span>
          <h3 class="heading_h4" style="margin: 0.75rem 0;">Menus inspired by the Bay Area</h3>
          <p class="paragraph" style="margin: 0; color: #4b5563;">
            Enjoy chef-crafted dishes, creative setups, and fresh local flavors. Our catering brings warmth, style, and ease to every event.
          </p>
        </div>
      </div>

    </div>
  </section>

  <!-- PHOTO GALLERY STRIP -->
  <section style="padding: 0 1.5rem 6rem;">
    <div style="max-width: 1280px; margin: 0 auto;">
      <h2 class="heading_h2" style="margin: 0 0 2rem; text-align: center;">Gatherings that inspire, moments that last</h2>
      <p class="subheading" style="text-align: center; max-width: 600px; margin: 0 auto 3rem;">
        Step inside our venues and events — discover the vibrant energy, unique details, and unforgettable experiences that bring every celebration to life.
      </p>
      <div id="gallery-grid" style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.75rem;">
        <img src="/images/gallery-1.jpg" alt="Event moment" style="width: 100%; aspect-ratio: 1; object-fit: cover; border-radius: 0.5rem; background: #f3f4f6;" />
        <img src="/images/gallery-2.jpg" alt="Event moment" style="width: 100%; aspect-ratio: 1; object-fit: cover; border-radius: 0.5rem; background: #f3f4f6;" />
        <img src="/images/gallery-3.jpg" alt="Event moment" style="width: 100%; aspect-ratio: 1; object-fit: cover; border-radius: 0.5rem; background: #f3f4f6;" />
        <img src="/images/gallery-4.jpg" alt="Event moment" style="width: 100%; aspect-ratio: 1; object-fit: cover; border-radius: 0.5rem; background: #f3f4f6;" />
        <img src="/images/gallery-5.jpg" alt="Event moment" style="width: 100%; aspect-ratio: 1; object-fit: cover; border-radius: 0.5rem; background: #f3f4f6;" />
        <img src="/images/gallery-6.jpg" alt="Event moment" style="width: 100%; aspect-ratio: 1; object-fit: cover; border-radius: 0.5rem; background: #f3f4f6;" />
        <img src="/images/gallery-7.jpg" alt="Event moment" style="width: 100%; aspect-ratio: 1; object-fit: cover; border-radius: 0.5rem; background: #f3f4f6;" />
        <img src="/images/gallery-8.jpg" alt="Event moment" style="width: 100%; aspect-ratio: 1; object-fit: cover; border-radius: 0.5rem; background: #f3f4f6;" />
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section style="background: #f9fafb; padding: 6rem 1.5rem;">
    <div style="max-width: 800px; margin: 0 auto;">
      <h2 class="heading_h2" style="margin: 0 0 0.75rem;">Event FAQs, answered simply</h2>
      <p class="subheading" style="margin: 0 0 3rem;">
        Get quick answers about our venues, catering, and planning process. We're here to help you create a seamless, memorable event — every step of the way.
      </p>
      <div style="display: flex; flex-direction: column; gap: 0;">

        <details style="border-top: 1px solid #e5e7eb; padding: 1.25rem 0;">
          <summary style="font-size: 1.05rem; font-weight: 500; cursor: pointer; list-style: none; display: flex; justify-content: space-between; align-items: center;">
            What kinds of events do you host?
            <span style="font-size: 1.5rem; font-weight: 300; line-height: 1;">+</span>
          </summary>
          <p class="paragraph" style="margin: 1rem 0 0; color: #4b5563;">
            Our spaces are perfect for everything from team offsites and product launches to milestone birthdays and casual get-togethers. We'll help you find the right fit for your vision.
          </p>
        </details>

        <details style="border-top: 1px solid #e5e7eb; padding: 1.25rem 0;">
          <summary style="font-size: 1.05rem; font-weight: 500; cursor: pointer; list-style: none; display: flex; justify-content: space-between; align-items: center;">
            How does catering work here?
            <span style="font-size: 1.5rem; font-weight: 300; line-height: 1;">+</span>
          </summary>
          <p class="paragraph" style="margin: 1rem 0 0; color: #4b5563;">
            Choose from chef-crafted menus, seasonal specialties, and flexible service — drop-off or full-service. We'll help you customize every detail, from taco bars to plated dinners.
          </p>
        </details>

        <details style="border-top: 1px solid #e5e7eb; padding: 1.25rem 0;">
          <summary style="font-size: 1.05rem; font-weight: 500; cursor: pointer; list-style: none; display: flex; justify-content: space-between; align-items: center;">
            Can I see the venues first?
            <span style="font-size: 1.5rem; font-weight: 300; line-height: 1;">+</span>
          </summary>
          <p class="paragraph" style="margin: 1rem 0 0; color: #4b5563;">
            Absolutely! Book a tour — virtual or in-person — to explore our spaces, get a feel for the vibe, and ask any questions. We'll work around your schedule.
          </p>
        </details>

        <details style="border-top: 1px solid #e5e7eb; border-bottom: 1px solid #e5e7eb; padding: 1.25rem 0;">
          <summary style="font-size: 1.05rem; font-weight: 500; cursor: pointer; list-style: none; display: flex; justify-content: space-between; align-items: center;">
            Are your venues accessible and easy to reach?
            <span style="font-size: 1.5rem; font-weight: 300; line-height: 1;">+</span>
          </summary>
          <p class="paragraph" style="margin: 1rem 0 0; color: #4b5563;">
            Yes, all our locations are accessible and close to BART, MUNI, and major SF landmarks. We're happy to share parking and accessibility info for each space.
          </p>
        </details>

      </div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section style="background: #000; padding: 6rem 1.5rem; text-align: center;">
    <div style="max-width: 600px; margin: 0 auto;">
      <h2 class="heading_h2 reveal" style="color: #fff; margin: 0 0 1rem;">Plan your next unforgettable gathering</h2>
      <p class="subheading" style="color: rgba(255,255,255,0.7); margin: 0 0 2.5rem;">
        Distinctive venues. Chef-driven menus. Seamless events.
      </p>
      <a href="/host-your-event" class="button on-inverse">Get started</a>
    </div>
  </section>

</Layout>

<style>
  @media (min-width: 768px) {
    #intro-grid       { grid-template-columns: 1fr 1fr !important; }
    #value-grid       { grid-template-columns: repeat(3, 1fr) !important; }
    #venues-grid      { grid-template-columns: repeat(2, 1fr) !important; }
    #editorial-grid   { grid-template-columns: 1.5fr 1fr !important; }
    #gallery-grid     { grid-template-columns: repeat(4, 1fr) !important; }
  }
  @media (min-width: 1024px) {
    #venues-grid      { grid-template-columns: repeat(4, 1fr) !important; }
    #editorial-grid   { grid-template-columns: 2fr 1fr 1fr !important; }
  }

  details summary::-webkit-details-marker { display: none; }
  details[open] summary span { transform: rotate(45deg); display: inline-block; }
</style>