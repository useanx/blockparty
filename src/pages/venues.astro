---
import Layout from '../layouts/Layout.astro';
import { venues } from '../data/venues';
---

<Layout
  title="Venue | Block Party Productions - Distinctive Event Venues in San Francisco"
  description="Discover Block Party Productions' portfolio of unique venues in San Francisco's SoMa. Perfect for diverse events, our spaces offer character, style, and top-notch service."
  ogTitle="Explore Our Portfolio | Block Party Productions"
  ogDescription="From Local Kitchen to Buena Vida Cantina, learn about our distinctive venues designed for memorable gatherings."
>

  <!-- HERO -->
  <section style="position: relative; min-height: 60vh; display: flex; align-items: center; justify-content: center; overflow: hidden; background: #111;">
    <img
      src="/images/hero-venues.jpg"
      alt="Our venues"
      style="position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0.5;"
    />
    <div style="position: relative; z-index: 1; text-align: center; padding: 2rem 1.5rem; max-width: 800px; margin: 0 auto;">
      <h1 class="heading_h2" style="color: #fff; margin: 0 0 1.5rem;">Our Venues</h1>
      <h2 class="heading_h3" style="color: #fff; font-weight: 400; margin: 0 0 1.5rem;">Bold spaces. Seamless vibes.</h2>
      <p class="subheading" style="color: rgba(255,255,255,0.85); max-width: 680px; margin: 0 auto;">
        Tucked into the heart of SoMa, our venues are just steps from Salesforce Tower, Moscone Center, Oracle Park, and BART — making them as convenient as they are unforgettable.
      </p>
    </div>
  </section>

  <!-- INTRO TEXT -->
  <section style="max-width: 800px; margin: 0 auto; padding: 5rem 1.5rem 3rem;">
    <p class="paragraph_large" style="color: #4b5563; text-align: center;">
      We offer a collection of uniquely styled venues conveniently located in the heart of San Francisco, each designed to host events that feel intentional, elevated, and effortless. Whether you're planning a corporate offsite, client dinner, or private celebration, our spaces pair thoughtful ambiance with exceptional service and culinary experiences that leave a lasting impression.
    </p>
  </section>

  <!-- VENUES LIST -->
  <section style="max-width: 1280px; margin: 0 auto; padding: 0 1.5rem 6rem;">
    <div style="display: flex; flex-direction: column; gap: 5rem;">
      {venues.map((venue, index) => (
        <div
          id={`venue-row-${index}`}
          style="display: grid; grid-template-columns: 1fr; gap: 2.5rem; align-items: center;"
        >
          <div style="border-radius: 1rem; overflow: hidden; aspect-ratio: 16/9; background: #f3f4f6;">
            <img
              src={`/images/venue-${venue.slug}.jpg`}
              alt={venue.name}
              style="width: 100%; height: 100%; object-fit: cover;"
            />
          </div>
          <div style="display: flex; flex-direction: column; gap: 1rem;">
            <p class="paragraph_small text-color_secondary" style="margin: 0;">Venue</p>
            <h2 class="heading_h2" style="margin: 0;">{venue.name}</h2>
            
              href={`https://maps.google.com/?q=${encodeURIComponent(venue.address)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="address text-link"
              style="display: inline-block;"
            >
              {venue.address}
            </a>
            <p class="paragraph_large" style="margin: 0; color: #4b5563;">{venue.tagline}</p>
            <div style="display: flex; gap: 1rem; flex-wrap: wrap; margin-top: 0.5rem;">
              <a href={`/${venue.slug}`} class="button is-secondary">View Venue</a>
              <a href="/host-your-event" class="button">Book This Space</a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section style="background: #f9fafb; padding: 6rem 1.5rem;">
    <div style="max-width: 1280px; margin: 0 auto;">
      <h2 class="heading_h2" style="margin: 0 0 3rem; text-align: center;">What our clients are saying</h2>
      <div id="testimonials-grid" style="display: grid; grid-template-columns: 1fr; gap: 2rem;">

        <div style="background: #fff; border-radius: 1rem; padding: 2rem; border: 1px solid #e5e7eb;">
          <p class="paragraph_large" style="margin: 0 0 1.5rem; font-style: italic;">
            "The event went great! Everyone loved the space and the food was incredible. The entire staff were extremely friendly and helpful, but I do want to give a special shoutout to Sarah! She was beyond amazing and attentive to everything. Thank you to you and everyone on your team for all the help and support!"
          </p>
          <p style="font-weight: 600; margin: 0 0 0.25rem;">Rebecca Rodl</p>
          <p class="paragraph_small text-color_secondary" style="margin: 0;">West Monroe</p>
        </div>

        <div style="background: #fff; border-radius: 1rem; padding: 2rem; border: 1px solid #e5e7eb;">
          <p class="paragraph_large" style="margin: 0 0 1.5rem; font-style: italic;">
            "Thank you for all your help in securing a happy hour during Dreamforce last week. We had a wonderful weather evening and Nicholas and Caitlyn were very attentive. The food was delicious and Caitlyn did a fantastic job of hopping around and making sure all new arrivals were offered a drink. Nicholas helped with the music and atmosphere and we all had a really lovely evening."
          </p>
          <p style="font-weight: 600; margin: 0 0 0.25rem;">Lynne Feeney</p>
          <p class="paragraph_small text-color_secondary" style="margin: 0;">Wilco Source</p>
        </div>

      </div>
    </div>
  </section>

  <!-- EMAIL SIGNUP -->
  <section style="background: #000; padding: 5rem 1.5rem;">
    <div style="max-width: 600px; margin: 0 auto; text-align: center;">
      <h2 class="heading_h3" style="color: #fff; margin: 0 0 1rem;">Host unforgettable events with us</h2>
      <p class="paragraph_large" style="color: rgba(255,255,255,0.7); margin: 0 0 2rem;">
        Ready to plan your next gathering? Discover unique venues, chef-driven menus, and seamless service. Join our community for inspiration, updates, and exclusive offers.
      </p>
      <form id="email-signup-form" style="display: flex; gap: 0.75rem; flex-wrap: wrap; justify-content: center;">
        <label for="signup-email" class="input_label screen-reader">Your email</label>
        <input
          type="email"
          id="signup-email"
          name="email"
          placeholder="Email address"
          required
          style="flex: 1; min-width: 240px; max-width: 360px; background: rgba(255,255,255,0.1); border-color: rgba(255,255,255,0.3); color: #fff;"
        />
        <button type="submit" class="button on-inverse">Subscribe</button>
      </form>
      <p id="signup-success" style="display: none; color: rgba(255,255,255,0.8); margin: 1rem 0 0; font-size: 0.875rem;">
        Thanks for joining our community!
      </p>
      <p id="signup-error" style="display: none; color: #fca5a5; margin: 1rem 0 0; font-size: 0.875rem;">
        Please try again — something went wrong.
      </p>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section style="max-width: 1280px; margin: 0 auto; padding: 6rem 1.5rem; text-align: center;">
    <h2 class="heading_h2" style="margin: 0 0 1rem;">Host unforgettable events with ease</h2>
    <p class="subheading" style="max-width: 500px; margin: 0 auto 2.5rem;">
      Distinctive venues. Chef-driven menus. Seamless events.
    </p>
    <a href="/host-your-event" class="button">Plan Your Event</a>
  </section>

</Layout>

<style>
  @media (min-width: 768px) {
    #testimonials-grid { grid-template-columns: 1fr 1fr !important; }
  }
  @media (min-width: 900px) {
    [id^="venue-row-"] { grid-template-columns: 1fr 1fr !important; }
  }
</style>

<script>
  const form = document.getElementById('email-signup-form') as HTMLFormElement;
  const success = document.getElementById('signup-success');
  const error = document.getElementById('signup-error');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = (document.getElementById('signup-email') as HTMLInputElement)?.value;

    try {
      const res = await fetch('/api/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      });
      if (res.ok) {
        form.style.display = 'none';
        if (success) success.style.display = 'block';
      } else {
        if (error) error.style.display = 'block';
      }
    } catch {
      if (error) error.style.display = 'block';
    }
  });
</script>