---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Page Not Found"
  description="The page you're looking for doesn't exist. Head back to Block Party Productions to find our venues, catering, and event planning services."
>

  <section style="min-height: 70vh; display: flex; align-items: center; justify-content: center; padding: 4rem 1.5rem;">
    <div style="text-align: center; max-width: 560px;">

      <p style="font-size: 6rem; font-weight: 700; color: #f3f4f6; line-height: 1; margin: 0 0 0.5rem; letter-spacing: -0.04em;">
        404
      </p>

      <h1 class="heading_h2" style="margin: 0 0 1rem;">
        This page took the night off
      </h1>

      <p class="subheading" style="margin: 0 0 3rem;">
        Looks like this page doesn't exist — but our venues are very much open. Head back and find your next unforgettable gathering.
      </p>

      <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
        <a href="/" class="button">Back to home</a>
        <a href="/venues" class="button is-secondary">Browse venues</a>
      </div>

      <div style="margin-top: 4rem; padding-top: 3rem; border-top: 1px solid #f3f4f6;">
        <p class="paragraph_small text-color_secondary" style="margin: 0 0 1rem;">
          Looking for something specific?
        </p>
        <div style="display: flex; gap: 1.5rem; justify-content: center; flex-wrap: wrap;">
          <a href="/catering" class="text-link is-secondary">Catering</a>
          <a href="/host-your-event" class="text-link is-secondary">Host Your Event</a>
          <a href="/careers" class="text-link is-secondary">Careers</a>
        </div>
      </div>

    </div>
  </section>

</Layout>